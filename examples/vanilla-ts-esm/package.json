{
  "name": "demo-vanilla-ts-esm",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "author": "Mux, Inc.",
  "license": "MIT",
  "scripts": {
    "dev": "npm run esbuild -- --servedir=public --serve=0.0.0.0:8004",

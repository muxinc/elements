  "devDependencies": {
    "esbuild": "^0.25.1",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@mux/mux-active-viewer-count": "*",
    "@mux/mux-audio": "*",
    "@mux/mux-player": "*",
    "@mux/mux-uploader": "*",
    "@mux/mux-video": "*"
  }
}
